generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user") // "admin" | "user"
  createdAt DateTime @default(now())
  createdBy String?

  apiKey    String?  @unique
  apiKeyAt  DateTime?

  orderLogs OrderLog[]

  @@map("users")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model OrderLog {
  id          String   @id @default(cuid())
  userId      String
  provider    String   @default("v1") // "v1" | "v2"
  orderId     String   // provider order_id (raw dari ditznesia)
  publicId    String?  @unique // ID yang ditampilkan ke client API (v2: 8 digit obfuscated)
  service     String   // service code (e.g. "wa")
  serviceName String   // display name
  country     String
  countryId   Int?     // provider country id
  number      String
  costIdr     Int?     // harga provider saat order dibuat
  priceIdr    Int?     // harga jual ke user
  outcome     String   // "otp_received" | "expired" | "cancelled" | "timeout" | "pending"
  otp         String?  // OTP text saat outcome=otp_received
  otpAt       DateTime?
  status      String?  // raw status dari provider (PENDING/Sukses/TIME OUT/Dibatalkan)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([provider])
  @@map("order_logs")
}
