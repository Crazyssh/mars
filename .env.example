# =============================================
# mars — environment variables
# =============================================

# --- App ---
# Secret untuk encrypt session cookie. WAJIB minimal 32 char random.
# Generate: openssl rand -base64 48
SESSION_SECRET=ganti-dengan-string-random-minimal-32-character

# --- Database ---
DATABASE_URL="file:./data/mars.db"

# --- Bootstrap admin ---
# Dipakai sekali pas first boot via `npm run seed:admin`.
# Setelah itu admin bisa add/remove user lain dari /admin/users.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ganti-password-kuat
ADMIN_NAME=Admin

# --- Mars (ditznesia.id) auth ---
# Cookie session dari browser:
#  1. Login di ditznesia.id pakai browser
#  2. F12 → Application → Cookies → https://ditznesia.id
#  3. Copy value PHPSESSID & cf_clearance ke sini
MARS_PHPSESSID=
MARS_CF_CLEARANCE=

# --- Optional overrides ---
# MARS_BASE_URL=https://ditznesia.id
# MARS_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Safari/537.36
